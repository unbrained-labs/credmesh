{
  "name": "credmesh",
  "version": "0.1.0",
  "private": true,
  "description": "Programmable working capital for autonomous agents",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/credit-worker",
    "start": "npm run start --workspace=packages/credit-worker",
    "typecheck": "tsc --noEmit -p packages/credit-worker/tsconfig.json",
    "test:e2e": "tsx packages/credit-worker/test/e2e.ts"
  },
  "devDependencies": {
    "solc": "^0.8.24",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.4",
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "better-sqlite3": "^12.8.0",
    "chai": "^6.2.2",
    "forge-std": "github:foundry-rs/forge-std",
    "hardhat": "^3.3.0",
    "mppx": "^0.4.8",
    "viem": "^2.47.6"
  }
}
